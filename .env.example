PROJECT_NAME=自动化测试平台后端
VERSION=0.1.0
API_V1_PREFIX=/api/v1

DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/devtestbackend?charset=utf8mb4

JWT_SECRET_KEY=please-change-this-secret-key-for-devtestbackend
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

REDIS_URL=redis://127.0.0.1:6379/0

# MinIO / S3-compatible media storage. Keep the bucket private.
MINIO_ENDPOINT_URL=http://127.0.0.1:9000
MINIO_PUBLIC_ENDPOINT_URL=http://127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=testplatform
MINIO_REGION=us-east-1
MINIO_SECURE=false
MEDIA_MAX_IMAGE_BYTES=10485760
MEDIA_PRESIGNED_URL_EXPIRE_SECONDS=3600

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60
TEST_PLAN_SCHEDULER_ENABLED=true
TEST_PLAN_SCHEDULER_INTERVAL_SECONDS=30
TEST_PLAN_DEFAULT_TIMEZONE=Asia/Shanghai
TEST_PLAN_RUN_STALE_SECONDS=3600
TEST_PLAN_WEBHOOK_SECRET=
TEST_PLAN_WEBHOOK_MAX_AGE_SECONDS=300
SNAPSHOT_ENCRYPTION_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

BACKEND_CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]
